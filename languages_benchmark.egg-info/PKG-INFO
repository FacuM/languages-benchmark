    let mut total = 0i64;
    for token in text.split_whitespace() {
        match token {
            "good" | "great" | "happy" | "clean" | "fast" | "love" => total += 1,
            "bad" | "sad" | "dirty" | "slow" | "hate" | "poor" => total -= 1,
            _ => {}
        }
    }
    println!("{}", total);
}
